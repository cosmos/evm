{
  "name": "cosmos-evm-contracts",
  "packageManager": "pnpm@9.15.0",
  "version": "0.0.14",
  "description": "A collection of smart contracts used in the development of the Cosmos EVM blockchain.",
  "devDependencies": {
    "@account-abstraction/contracts": "^0.8.0",
    "@openzeppelin/contracts": "^5.4.0",
    "@types/node": "^22.0.0",
    "@wagmi/cli": "^2.2.0",
    "hardhat": "^3.1.10",
    "tsdown": "^0.21.0",
    "typescript": "^5.0.0"
  },
  "scripts": {
    "clean:precompiles-build": "node ./scripts/clean-precompiles-build.mjs",
    "build:precompiles": "pnpm run clean:precompiles-build && pnpm exec hardhat compile && wagmi generate && tsdown",
    "prepublishOnly": "pnpm run build:precompiles"
  },
  "files": [
    "dist",
    "precompiles",
    "README.md"
  ],
  "exports": {
    "./precompiles/*.sol": "./precompiles/*.sol",
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.cjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cosmos/evm.git"
  },
  "author": "Cosmos Labs",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/cosmos/evm/issues"
  },
  "homepage": "https://github.com/cosmos/evm#readme",
  "type": "module"
}
